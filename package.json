{
  "name": "agent-empires",
  "version": "0.1.0",
  "description": "RTS command center for AI business agents",
  "author": "heymitch",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "rts",
    "agents",
    "ai",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "agent-empires": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "hooks/",
    "dist/",
    "!dist/**/*.map",
    "data/.gitkeep"
  ],
  "scripts": {
    "predev": "node scripts/validate-config.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "deploy": "./scripts/deploy.sh",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "chokidar": "^4.0.0",
    "pixi.js": "^8.17.0",
    "tone": "^15.1.22",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
